# Database
DB_HOST=my_postgres
DB_USER=postgres
DB_PASS=postgres
DB_NAME=game-baza
DB_PORT=5432

# Agent
API_KEY=your_api_key_here
SERVER_NAME=my-server
WS_INTERVAL=2

# Runtime
HOST=0.0.0.0
PORT=8080              # фронт ждёт WS на :8080/metrics
LOG_LEVEL=info        # dev: debug

# Role: "base" (центральный узел) или "node" (сборщик метрик)
ROLE=base
BASE_URL=http://localhost:8080   # для ROLE=node — адрес base-инстанса
PUSH_INTERVAL=2

# Сбор и хранение метрик
COLLECT_INTERVAL=1    # как часто инстанс снимает свои метрики, сек
HISTORY_WINDOW=60     # сколько последних снапшотов хранить в памяти на сервер

# Retention: удаление старых снапшотов из БД
RETENTION_DAYS=7      # хранить снапшоты не старше N дней
RETENTION_INTERVAL=3600  # как часто запускать чистку, сек

# Сеть
HTTP_TIMEOUT=5        # таймаут исходящих запросов ноды на base, сек
CORS_ORIGINS=*        # разрешённые origin'ы через запятую, напр: https://bromage.ru,http://localhost:5173
